model Feedback {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  rating        Int      // 1-5
  category      String?
  workingWell   String?  @map("working_well")
  couldBeBetter String?  @map("could_be_better")
  createdAt     DateTime @default(now()) @map("created_at")

