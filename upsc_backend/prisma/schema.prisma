  @@unique([topicId, name])
  @@map("syllabus_sub_topics")
}

// ==================== PYQ MAINS EVALUATION ====================

model PyqMainsAttempt {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  pyqMainsQuestionId String    @map("pyq_mains_question_id")
  answerText    String?   @map("answer_text")
  fileUrl       String?   @map("file_url")
  wordCount     Int       @default(0) @map("word_count")
  submittedAt   DateTime? @map("submitted_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  user       User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  mainsQuestion   PYQMainsQuestion    @relation(fields: [pyqMainsQuestionId], references: [id], onDelete: Cascade)
  evaluation PyqMainsEvaluation?

  @@index([userId, pyqMainsQuestionId])
  @@map("pyq_mains_attempts")
}

model PyqMainsEvaluation {
  id               String    @id @default(uuid())
  attemptId        String    @unique @map("attempt_id")
  score            Float
  maxScore         Float     @map("max_score")
  status           String    @default("pending") // pending, evaluating, completed
  strengths        String[]
  improvements     String[]
  suggestions      String[]
  detailedFeedback String?   @map("detailed_feedback")
  evaluatedAt      DateTime? @map("evaluated_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  attempt PyqMainsAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@map("pyq_mains_evaluations")
}

// ==================== MOCK TEST MAINS EVALUATION ====================

model MockTestMainsAttempt {
  id                 String    @id @default(uuid())
  userId             String    @map("user_id")
  mockTestId         String    @map("mock_test_id")
  mockTestQuestionId String    @map("mock_test_question_id")
  answerText         String?   @map("answer_text")
  fileUrl            String?   @map("file_url")
  wordCount          Int       @default(0) @map("word_count")
  submittedAt        DateTime? @map("submitted_at")
  createdAt          DateTime  @default(now()) @map("created_at")

  user       User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  mockTest   MockTest                  @relation(fields: [mockTestId], references: [id], onDelete: Cascade)
  question   MockTestQuestion          @relation(fields: [mockTestQuestionId], references: [id], onDelete: Cascade)
  evaluation MockTestMainsEvaluation?

  @@index([userId, mockTestId])
  @@map("mock_test_mains_attempts")
}

model MockTestMainsEvaluation {
  id               String    @id @default(uuid())
  attemptId        String    @unique @map("attempt_id")
  score            Float
  maxScore         Float     @map("max_score")
  status           String    @default("pending") // pending, evaluating, completed
  strengths        String[]
  improvements     String[]
  suggestions      String[]
  detailedFeedback String?   @map("detailed_feedback")
  evaluatedAt      DateTime? @map("evaluated_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  attempt MockTestMainsAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@map("mock_test_mains_evaluations")
}
