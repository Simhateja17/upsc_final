{
  "name": "backend",
  "version": "1.0.0",
  "description": "UPSC Backend API with Express, TypeScript, Prisma and Supabase",
  "main": "dist/index.js",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--dns-result-order=ipv4first tsx watch src/index.ts",
    "build": "prisma generate && tsc",
    "start": "NODE_OPTIONS=--dns-result-order=ipv4first node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "prisma:studio": "prisma studio",
    "lint": "tsc --noEmit",
    "seed:cms": "npx tsx prisma/seed-cms.ts"
  },
  "keywords": [
    "upsc",
    "express",
    "typescript",
    "prisma",
    "supabase"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@azure/openai": "^2.0.0",
    "@google/genai": "^1.46.0",
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "@supabase/supabase-js": "^2.50.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.3.2",
    "@types/node-cron": "^3.0.11",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.16.0",
    "@types/string-similarity": "^4.0.2",
    "axios": "^1.13.6",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "ioredis": "^5.10.1",
    "jose": "^6.2.1",
    "multer": "^2.1.0",
    "node-cron": "^4.2.1",
    "openai": "^6.33.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.19.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "rate-limit-redis": "^4.3.1",
    "resend": "^6.9.3",
    "rss-parser": "^3.13.0",
    "string-similarity": "^4.0.4",
    "undici": "^7.24.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/pino-http": "^5.8.4",
    "cross-env": "^10.1.0",
    "nodemon": "^3.1.14",
