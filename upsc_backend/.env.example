# ====================================
# UPSC Backend Environment Variables
# ====================================

# Server Configuration
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# ====================================
# Database (Supabase PostgreSQL)
# ====================================
# Get from: Supabase Dashboard > Settings > Database > Connection string
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres?schema=public"

# ====================================
# Supabase Configuration
# ====================================
# Get from: Supabase Dashboard > Settings > API
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=eyJ...   # Your anon/public key
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # Your service role key (keep secret!)

# ====================================
# Google OAuth (Optional)
# ====================================
GOOGLE_REDIRECT_URL=http://localhost:3000/auth/callback

USD_TO_INR=90                         # USD -> INR exchange rate for cost tracking

# ====================================
# Azure OpenAI (All AI Features)
# ====================================
# Get from: Azure Portal > Azure OpenAI resource > Keys and Endpoint
# Powers: Jeet AI chat, answer evaluation, editorial summarization, PYQ parsing,
#          question generation, and RAG embeddings

AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small   # Your embedding deployment name
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-5.4-mini                  # Your chat deployment name

# ====================================
# Resend (Email Notifications)
# ====================================
# Get from: https://resend.com/api-keys

RESEND_API_KEY=re_...              # Your Resend API key
RESEND_FROM_EMAIL=noreply@yourdomain.com  # Must be verified domain in Resend

# ====================================
# News API (Editorial/News Integration)
# ====================================
# Get from: https://newsapi.org/account
# Free tier: 100 requests/day, limited to headlines

NEWS_API_KEY=your_news_api_key_here  # Your News API key

# ====================================
# Quick Setup Checklist
# ====================================
# ✅ 1. Copy this file to .env
# ✅ 2. Fill in Supabase credentials (you already have these)
# ✅ 3. Create Resend account → Get API key
# ✅ 4. Set up Azure OpenAI resource → Get endpoint + API key
# ✅ 5. Get News API key → https://newsapi.org/register
# ✅ 6. Run: npx tsx src/test-services.ts (to verify)
# ✅ 7. Run: npx prisma db push (to create tables)
# ✅ 8. Start server: npm run dev